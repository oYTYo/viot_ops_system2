# =========================
# 前后端侧配置切换
# =========================
# 0 = 阿里云配置；1 = 电信配置。迁移时优先改这个字段。
VIOT_CMS_PROVIDER=0

# none = 不鉴权；token = 使用 VIOT_CMS_ACCESS_TOKEN；app = 使用 appId/appKey 自动换 token。
VIOT_CMS_AUTH_MODE=app

# 播放地址查询路径和登录路径，通常两套环境接口路径一致，只换 host。
VIOT_CMS_LIVESTREAM_PATH=/vic/cms/v1/camera/livestream
VIOT_CMS_LOGIN_PATH=/vic/account/v1/auth/loginByAppId
VIOT_CMS_TIMEOUT_SECONDS=8

# 后端数据库连接。迁移新服务器后如果 MySQL 地址/密码变了，只改这一行。
SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:bupt8-AIOps@localhost:3306/viot_ops_db?charset=utf8mb4

# 运行文件路径。迁移新服务器时如果目录不同，只改这里，不改代码。
VIOT_RUNTIME_PROFILE_FILE=/home/viot_ops_system2/backend/runtime_profile.json
VIOT_ACTIVE_FLOW_CACHE_FILE=/home/viot_ops_system2/backend/active_flows_cache.json
VIOT_LOCAL_CAMERA_CONFIG_FILE=/home/viot_ops_system2/backend/local_cameras.json
VIOT_CHAINLIST_FILE=/home/monitor_realtime/chainlist.json
VIOT_MATCH_SCRIPT_PATH=/home/monitor_realtime/network/match_uplink_downlink_flows.py
VIOT_ANOMALY_LOG_FILE=/home/monitor_realtime/anomaly_log.jsonl
VIOT_NETWORK_MATCH_FALLBACK_FILES=/home/monitor_realtime/network/uplink_downlink_match copy.json,/home/monitor_realtime/network/uplink_downlink_match.json
VIOT_CAMERA_PLAYBACK_MAP_FILE=/home/viot_ops_system2/backend/camera_playback_map.json

# 阿里云 CMS/智融配置。VIOT_CMS_PROVIDER=0 时使用。
VIOT_CMS_PROVIDER_0_BASE_URL=http://172.29.151.209:9192
VIOT_CMS_PROVIDER_0_AUTH_BASE_URL=http://172.29.151.209:20002
VIOT_CMS_PROVIDER_0_APP_ID=831000003
VIOT_CMS_PROVIDER_0_APP_KEY=rebB6FT74H%UrXQhxC&a2wscXALrsZ$W
VIOT_CMS_PROVIDER_0_LOGIN_NONCE=6310372240
VIOT_CMS_PROVIDER_0_ACCESS_TOKEN_CACHE_FILE=/home/viot_ops_system2/backend/.cms_access_token_aliyun.json

# 电信 CMS/智融配置。VIOT_CMS_PROVIDER=1 时使用。
VIOT_CMS_PROVIDER_1_BASE_URL=http://10.108.3.80:9192
VIOT_CMS_PROVIDER_1_AUTH_BASE_URL=http://10.108.3.80:20002
